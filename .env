#ANTHROPIC_BASE_URL = "https://open.bigmodel.cn/api/anthropic"
#ANTHROPIC_API_KEY = "YOUR API KEY"

# 文本模型
MODEL_ID = "GLM-5.1"
# 图片理解模型
IMAGE_MODEL_ID = "kimi-k2.5"
# thinking(enabled or disabled or adaptive)
LLM_THINKING_TYPE = "enabled"
BUDGET_TOKENS = 4096

# Summary model for context compression (optional, defaults to MODEL_ID)
SUMMARY_MODEL = "GLM-5.1"

# 模型上下文窗口
LLM_MAX_WINDOW = 200000

# 默认初始化时, 从memory加载的消息轮数
# 超过 KEEP_RECENT_ROUNDS 或者 TOKEN_RATIO_AFTER_COMPACT 阈值时, 前面的部分会被压缩
INIT_RECENT_ROUNDS = 10

# 上下文压缩策略,
# 触发条件: ≥ 150kb,
# 压缩后: 不超过 KEEP_RECENT_ROUNDS 轮兑换 and 当前token不超过 TOKEN_RATIO_AFTER_COMPACT
KEEP_RECENT_ROUNDS = 30
# Token ratio after context compression (default: 0.3)
TOKEN_RATIO_AFTER_COMPACT = 0.3

# 关闭对 tool_result 和 thinking的处理，看下缓存命中率
# N 轮之前的 tool_result 需要压缩（默认 5 轮）
TOOL_RESULT_COMPACT_ROUNDS = 5999999
# N 轮之前的 thinking 块会被删除（默认 3 轮）
# 降低上下文 token 数量，保留最近 N 轮的思考过程
THINKING_REMOVE_ROUNDS = 399999


# Memory Retrieval Configuration

# 嵌入模型名称
# 推荐选项（速度对比）：
# - sentence-transformers/all-MiniLM-L6-v2  : 22MB，最快，适合英文/简单中文（默认）
# - BAAI/bge-small-zh-v1.5                  : 100MB+，中文更好但慢3-5倍
EMBEDDING_MODEL = "BAAI/bge-small-zh-v1.5"

# 模型加载优化（MacBook 建议开启）
# EMBEDDING_FORCE_CPU = true  # 强制使用 CPU，避免 MPS 加载不稳定（默认开启）
# 模型本地缓存目录（首次下载后，后续从本地加载约3-5秒）
MODEL_CACHE_DIR = "/Users/jiaye/dev/ghostagent/models"

# 检索时返回的相关记忆条数
MEMORY_TOP_K = 5

# 信息检索召回条件: score ≥ bm25_threshold AND score ≥ vector_threshold
# 向量相似度阈值
MEMORY_VECTOR_THRESHOLD = 0.5

# BM25 分数阈值
MEMORY_BM25_THRESHOLD = 5.0

# 索引过滤配置（逗号分隔, 不配置是默认全部）
# 可选Roles: user, assistant
# MEMORY_INDEX_ROLES = user,assistant
MEMORY_INDEX_ROLES = assistant

# skills
SKILL_PATH = "/Users/jiaye/dev/ghostagent/skills"
# browser
chrome_path = "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
chrome_fetch_timeout = 20000
chrome_debug_port = 9222

# log
LOGURU_LEVEL = INFO
log_dir = "/Users/jiaye/dev/ghostagent/logs"

# 默认使用的搜索引擎 google or baidu
web_search_engine = "baidu"
#web_search_engine = "google"

# Memory directory for conversation persistence (new format)
# Structure: memory/{session_id}/{YYYY-MM-DD}.jsonl
MEMORY_DIR = "/Users/jiaye/dev/ghostagent/memory"

# Docker Sandbox Configuration
# Each tool can be set to "sandbox" (run in Docker) or "local" (run on host)
# Default is "local" for all tools
SANDBOX_BASH=local
SANDBOX_READ_FILE=local
SANDBOX_WRITE_FILE=local
SANDBOX_EDIT_FILE=local
# Docker image for sandbox containers
SANDBOX_IMAGE=python:3.11-slim
# Host directory for sandbox file persistence (bind mounted to /workspace in container)
# Structure: {SANDBOX_PERSIST_DIR}/{session_id}/
SANDBOX_PERSIST_DIR=/Users/jiaye/dev/ghostagent/sandbox_data
